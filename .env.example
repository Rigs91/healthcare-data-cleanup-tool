# Core app defaults
ALLOWED_ORIGINS=*
SESSION_SECRET_KEY=change-me-in-local-dev
UI_WORKFLOW_VERSION=v3_guided

# Optional Ollama-assisted planning
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_SECONDS=60

# Optional Google Drive connector settings (not used in the main public demo path)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/google/auth/callback
GOOGLE_OAUTH_SCOPE=https://www.googleapis.com/auth/drive.readonly
